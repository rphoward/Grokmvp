---
description: Pseudo-Lisp SOP for authoring Cursor-compatible .mdc rule files in this workspace — frontmatter contracts, focused splitting, legacy ports, and enforcement of consistent rule form across the set.
globs: .cursor/rules/**
---

(def-sop mdc-authoring
  (context
    (target "cursor-rule-authoring-agent")
    (optimization "maximum-determinism-minimum-slop-consistent-rule-set"))

  <central_idea>
  (center-of-gravity
    (invariant "Every .mdc rule file in this workspace must be a valid Cursor data structure with strict frontmatter contracts and minimal focused scope; authoring must perform structural subtraction to the smallest explicit unit, enforce a single consistent form across the entire rule set, and halt immediately on any ambiguity of rule purpose, applicability, or boundary."))
  </central_idea>

  (protocol-1-purpose-and-scope-grilling
    (pre-flight-inventory
      (execute-ide-search :targets '(".cursor/rules/*.mdc" "current rule set" "any legacy single-file rule formats present")))
    (grill-interrogation
      (if (or (ambiguous? purpose-of-rule-being-written)
              (ambiguous? when-it-should-activate)
              (ambiguous? boundary-of-its-responsibility))
          (progn
            (halt-generation)
            (query-human :count 1 :propose-recommendation t)
            (wait-for-resolution)))))

  (protocol-2-frontmatter-as-strict-applicability-contract
    (enforce (valid-cursor-frontmatter-only))
    (match activation-mode
      (:always-loaded (alwaysApply :true))
      (:auto-attach-on-files (globs "exact/**/pattern"))
      (:agent-decides-relevance (description "one-line purpose for the model to evaluate"))
      (otherwise (forbidden 'mixing-modes 'omitting-required-fields)))
    (valid-keys-only
      (assert (set-equals? (keys frontmatter) '(description alwaysApply globs)))
      (enforce (no-undocumented-keys))))

  (protocol-3-focused-rules-and-structural-subtraction
    (prefer (multiple-small-focused-rules over 'one-giant-always-on-blob))
    (if (rule-surface-exceeds-minimal-unit-for-its-purpose)
        (progn
          (execute-single-surgical-extraction :into-new-mdc-file)
          (reduce-surface-area)))
    (anti-ad-hoc-blob
      (assert (not (or (has-unstructured-prose-blob? diff)
                       (has-ad-hoc-sections? diff))))
      (remedy (extract-to 'dedicated-focused-mdc))))

  (protocol-4-legacy-porting
    (enforce (when-porting-from-single-file-formats
               (inventory-content)
               (port-only-useful-parts-to-scoped-mdc-files)
               (delete-legacy-form))))

  (protocol-5-set-wide-form-consistency
    (enforce (all-rules-in-this-workspace-must-use
               :valid-cursor-frontmatter
               :established-pseudo-lisp-def-sop-form
               :narrow-scope
               :no-bleed-between-rules))
    (assert (no-duplication-of-responsibility-with 'conduct 'safety 'thermonuclear 'any-other-rule))
    (forbidden 'embedding-coding-discipline 'embedding-safety-logic 'embedding-response-habits-into-authoring-rule)))