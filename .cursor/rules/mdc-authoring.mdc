---
description: Pseudo-Lisp SOP for writing composable Cursor .mdc rules — frontmatter schemas, structural subtraction, legacy ports, and cross-rule composability with thermonuclear invariants.
globs: .cursor/rules/**
---

(def-sop mdc-authoring
  (context
    (target "cursor-rule-authoring-agent")
    (optimization "maximum-determinism-minimum-slop-composable-rules"))

  <central_idea>
  (center-of-gravity
    (invariant "Every .mdc rule file is a data structure that drives agent behavior strictly downstream of its form; authoring must perform structural subtraction to the smallest explicit composable unit, declare strict applicability contracts at the boundary via frontmatter, and halt/escalate immediately on any ambiguity of purpose, data shape, or scope."))
  </central_idea>

  (protocol-1-discovery-and-requirement-grilling
    (pre-flight-inventory
      (execute-ide-search :targets '(".cursor/rules/*.mdc" "current rules set" "legacy .cursorrules or equivalent if present")))
    (grill-interrogation
      (if (or (ambiguous? rule-purpose) (ambiguous? target-scope) (ambiguous? data-shape-driven-by-rule))
          (progn
            (halt-generation)
            (query-human :count 1 :propose-recommendation t)
            (wait-for-resolution)))))

  (protocol-2-frontmatter-as-strict-boundary-schema
    (frontmatter-contract
      (enforce (progn
        (description :one-line-picker-text)
        (match applicability-contract
          (:universal-short-habit (alwaysApply :true))
          (:path-folder-or-type-specific (globs "exact/**/pattern"))
          (otherwise (forbidden 'omitting-or-mixing-contracts)))))
      (valid-keys-only
        (assert (set-equals? (keys frontmatter) '(description alwaysApply globs)))
        (enforce (no-undocumented-keys :in-any-rule))))
    (application-guidance
      (always-apply-for (or 'conduct 'safety 'core-habits 'universal-invariants))
      (globs-for (or 'language-specific 'directory-specific 'workflow-specific))))

  (protocol-3-structural-subtraction-and-guaranteed-composability
    (bounded-focus
      (if (rule-surface-exceeds-minimal-focused-unit)
          (progn
            (execute-single-surgical-extraction :to-new-mdc)
            (reduce-surface-area))))
    (anti-ad-hoc-blob
      (assert (not (or (has-ad-hoc-sections? diff) (has-unstructured-prose-blob? diff))))
      (remedy (extract-to (or 'dedicated-focused-mdc 'policy-rule))))
    (legacy-port-as-typed-extraction
      (enforce (progn
        (inventory-legacy-blob)
        (port-only-useful-parts-to-scoped-mdc)
        (delete-legacy-blob-form))))
    (composability-with-existing-invariants
      (enforce (new-rule-satisfies-thermonuclear-principles
                 :data-structures-drive-behavior
                 :structural-subtraction
                 :explicit-boundaries
                 :halt-on-ambiguity))
      (assert (no-conflict-with 'thermonuclear 'conduct 'safety 'any-prior-focused-rule)))))